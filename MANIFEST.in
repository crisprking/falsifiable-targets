# MANIFEST.in for falsifiable-targets v1.4.1
#
# Tells setuptools which non-Python files to include in the source
# distribution (sdist). Without this, `pip install` from sdist drops
# the YAML data files the engine needs at runtime.
#
# For wheel installs (the more common path), package-data in
# pyproject.toml does the equivalent job — but the two configs must
# agree, so both are present.

# YAML data files the engine reads at runtime
include sentinels/*.yaml
include claims/*.yaml
include claims/paralog_map.yaml

# Package metadata
include _version.py
include LICENSE
include README.md
include CHANGELOG.md
include CITATION.cff
include CONTRIBUTING.md

# Documentation
recursive-include docs *.md

# Test data (so users can run pytest after install)
recursive-include tests *.py
recursive-include tests *.yaml

# Exclude caches and build artifacts
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .ae_cache
global-exclude reports
